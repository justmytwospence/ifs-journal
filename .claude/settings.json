{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm ci)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(npx biome *)",
      "Bash(npx prisma *)",
      "Bash(npx tsc *)",
      "Bash(npx tsx *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git ls-files *)",
      "Bash(git rev-parse *)",
      "Bash(rg *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(curl *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; case \"$f\" in *.ts|*.tsx|*.mjs|*.json) npx biome check --write \"$f\" ;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint > /tmp/ifs-lint.log 2>&1 && npx tsc --noEmit >> /tmp/ifs-lint.log 2>&1 || { cat /tmp/ifs-lint.log; exit 2; }",
            "asyncRewake": true,
            "timeout": 120,
            "rewakeSummary": "Lint or typecheck failed after turn"
          }
        ]
      }
    ]
  }
}
