# Database
DATABASE_URL="postgresql://[user]:[password]@[host]/[database]?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# Environment
NODE_ENV="development"

# Demo user — read-only account the /demo flow logs into. Must match
# the email seeded by prisma/seed.ts. isDemo in the session is derived
# by comparing user.email to this value (no client-supplied isDemo).
DEMO_USER_EMAIL="demo@ifsjournal.me"
# The demo password is read server-side only (never sent to the client).
DEMO_USER_PASSWORD="password123"

# Resend — transactional email (verification + password reset).
# Optional in dev: if unset, emails are logged to the server console.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="IFS Journal <noreply@your-domain.com>"

# Sentry — optional; when unset, errors fall through to console.
# SENTRY_DSN="https://...@sentry.io/..."
# NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
