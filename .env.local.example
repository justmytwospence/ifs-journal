# Database
# Two env vars: DATABASE_URL is the pooled URL (used by runtime queries via
# the Neon serverless adapter) and DATABASE_URL_UNPOOLED is the direct URL
# (used by `prisma migrate deploy` via Prisma's classic engine). The
# Neon-Vercel integration sets both on Production/Preview/Development.
#
# For local dev, the simplest setup is to set only DATABASE_URL_UNPOOLED to
# your local Postgres or Neon dev branch — `lib/db.ts` and the build script
# fall back to it when DATABASE_URL is unset.
#
# To pull the values Vercel currently has, run:
#   vercel env pull .env.local
DATABASE_URL="postgresql://[user]:[password]@[host]/[database]?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://[user]:[password]@[direct-host]/[database]?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# Environment
NODE_ENV="development"

# Demo user — read-only account the /demo flow logs into. Must match
# the email seeded by prisma/seed.ts. isDemo in the session is derived
# server-side by comparing the authenticated user's email to this value.
# No demo password: the seed hashes random bytes that are immediately
# discarded, and sign-in is routed through a passwordless NextAuth
# provider keyed on this email.
DEMO_USER_EMAIL="demo@ifsjournal.me"

# Admin emails — comma-separated allow-list of accounts that can reach
# /admin/*. Used by the eval-snapshots dashboard and any future dev-only
# surfaces. isAdmin in the session is derived server-side by membership
# in this set; non-admins get a 404 (not a 403) so the route doesn't leak.
# Leave empty in production unless you have admin accounts; the route
# disappears for everyone if unset.
# ADMIN_EMAILS="you@example.com,teammate@example.com"

# Resend — transactional email (verification + password reset).
# Optional in dev: if unset, emails are logged to the server console.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="IFS Journal <noreply@your-domain.com>"

# Sentry — optional; when unset, errors fall through to console.
# SENTRY_DSN="https://...@sentry.io/..."
# NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
