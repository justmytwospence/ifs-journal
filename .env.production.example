# Production Environment Variables for Vercel

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://[user]:[password]@[host]/[database]?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="[generate with: openssl rand -base64 32]"
NEXTAUTH_URL="https://your-app.vercel.app"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."

# Environment
NODE_ENV="production"

# Demo user — read-only account the /demo flow logs into. REQUIRED in
# production: prisma/seed.ts refuses to run with defaults, and the server-
# derived isDemo flag only matches when DEMO_USER_EMAIL is set. Leaving
# DEMO_USER_PASSWORD blank would otherwise ship a publicly-known password.
DEMO_USER_EMAIL="demo@ifsjournal.me"
DEMO_USER_PASSWORD="change-me-to-a-random-string"

# Resend — required in production for verification + password reset emails.
RESEND_API_KEY="re_..."
EMAIL_FROM="IFS Journal <noreply@your-domain.com>"

# Sentry — error reporting. NEXT_PUBLIC_SENTRY_DSN is for the browser bundle
# (public is fine — DSNs are public identifiers). SENTRY_DSN is for server.
SENTRY_DSN="https://...@sentry.io/..."
NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
# Source-map upload at build time (so prod stack traces aren't minified).
# SENTRY_AUTH_TOKEN must stay secret. When any of these are unset the build
# skips source-map upload but otherwise runs normally.
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"
SENTRY_AUTH_TOKEN="sntrys_..."
